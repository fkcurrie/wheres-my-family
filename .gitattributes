# Force normalization of line endings in git
* text=auto

# Enforce LF on bash and PowerShell scripts so they execute correctly on Linux/macOS
*.sh text eol=lf
*.ps1 text eol=lf
gradlew text eol=lf

# Enforce CRLF on Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Make sure image and binary files are handled as binary
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
*.keystore -text
*.jks -text
